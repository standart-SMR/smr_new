/* Выбор навигации */
function goToNavChoice() { setView('navChoice'); crumb(['Главная']); }
function goToSectionsNav() { renderSections(); }
function goToZonesNav() { renderZones(); }

/* Зоны */
function getAllZones() {
  var cnt = {};
  rawData.forEach(function(r) {
    (r.zone||'').split(',').forEach(function(z) {
      z=z.trim(); if(z) cnt[z]=(cnt[z]||0)+1;
    });
  });
  return Object.entries(cnt).sort(function(a,b){return b[1]-a[1];});
}
function getZoneSubsections(zone) {
  var set=new Set();
  rawData.filter(function(r){return inZone(r,zone);}).forEach(function(r){if(r.ss)set.add(r.ss);});
  return [...set].sort();
}
function getZoneDetails(zone,ss) {
  var seen=new Set(),res=[];
  rawData.filter(function(r){return inZone(r,zone)&&r.ss===ss;}).forEach(function(r){
    if(!seen.has(r.d)){seen.add(r.d);res.push(r.d);}
  });
  return res;
}
function getZoneSolutions(zone,ss,d) {
  return rawData.filter(function(r){return inZone(r,zone)&&r.ss===ss&&r.d===d;});
}
function inZone(rec,zone) {
  return (rec.zone||'').split(',').map(function(z){return z.trim();}).includes(zone);
}
function renderZones() {
  setView('zones'); crumb(['Главная','Зоны применения']);
  clearChildren(els.zonesGrid);
  getAllZones().forEach(function(pair) {
    var zone=pair[0], cnt=pair[1];
    var btn=document.createElement('button');
    btn.className='card-btn zone-card';
    btn.innerHTML='<span>'+escapeHtml(zone)+'</span><span class="zone-count">'+cnt+'</span>';
    btn.onclick=function(){selectZone(zone);};
    els.zonesGrid.appendChild(btn);
  });
}
function selectZone(zone) {
  state.zone=zone; setView('zoneSubsections');
  crumb(['Главная','Зоны применения',zone]);
  document.getElementById('zone-title').textContent=zone;
  clearChildren(els.zoneSubsectionsGrid);
  getZoneSubsections(zone).forEach(function(ss) {
    var btn=document.createElement('button');
    btn.className='card-btn'; btn.textContent=ss;
    btn.onclick=function(){selectZoneSS(ss);};
    els.zoneSubsectionsGrid.appendChild(btn);
  });
}
function selectZoneSS(ss) {
  state.zone_ss=ss; setView('zoneDetails');
  crumb(['Главная','Зоны применения',state.zone,ss]);
  document.getElementById('zone-ss-title').textContent=ss;
  clearChildren(els.zoneDetailsGrid);
  getZoneDetails(state.zone,ss).forEach(function(d) {
    var sols=getZoneSolutions(state.zone,ss,d);
    var btn=document.createElement('button');
    btn.className='card-btn zone-card';
    var t=document.createElement('span'); t.textContent=d; btn.appendChild(t);
    if(sols.length){var b=document.createElement('span');b.className='zone-count';b.textContent=sols.length+' '+(sols.length===1?'решение':sols.length<5?'решения':'решений');btn.appendChild(b);}
    btn.onclick=function(){selectZoneDetail(d);};
    els.zoneDetailsGrid.appendChild(btn);
  });
}
function selectZoneDetail(d) {
  state.zone_d=d; setView('zoneSolutions');
  crumb(['Главная','Зоны применения',state.zone,state.zone_ss,d]);
  document.getElementById('zone-detail-title').textContent=d;
  clearChildren(els.zoneSolutionsList);
  getZoneSolutions(state.zone,state.zone_ss,d).forEach(function(item){
    var w=document.createElement('details'); w.className='item';
    var s=document.createElement('summary');
    var tr=document.createElement('div'); tr.className='summary-title-row';
    tr.textContent=item.ss+' / '+item.d; s.appendChild(tr); w.appendChild(s);
    var b=document.createElement('div'); b.className='body';
    b.appendChild(buildSolutionBlock(item,null)); w.appendChild(b);
    els.zoneSolutionsList.appendChild(w);
  });
}
function crumb(parts) {
  if(!els.crumbs) return;
  els.crumbs.innerHTML=parts.map(function(p,i){
    return i===0?'<span class="crumb-link" onclick="renderHub()">'+escapeHtml(p)+'</span>':'<span> / '+escapeHtml(p)+'</span>';
  }).join('');
}
function renderSections() {
  setView('sections');
  clearChildren(els.sectionsGrid);
  getSections().forEach(sec => {
    els.sectionsGrid.appendChild(makeCardButton(sec, () => selectSection(sec)));
  });
  updateCrumbs();
}

function renderSubsections() {
  setView('subsections');
  clearChildren(els.subsectionsGrid);
  getSubsections(state.section).forEach(ss => {
    els.subsectionsGrid.appendChild(makeCardButton(ss, () => selectSubsection(ss)));
  });
  updateCrumbs();
}

function renderDetails() {
  setView('details');
  showToolbar('toolbar');
  clearChildren(els.detailsList);
  const details = getDetails(state.section, state.subsection);
  if (details.length === 0) {
    const empty = document.createElement('div');
    empty.className = 'no-results';
    empty.textContent = 'Нет данных для отображения';
    els.detailsList.appendChild(empty);
  } else {
    details.forEach(det => {
      els.detailsList.appendChild(buildDetailItem(state.section, state.subsection, det));
    });
  }
  updateCrumbs();
}

function renderSearchResults(query) {
  state.section = null;
  state.subsection = null;
  setView('search');
  showToolbar('toolbar-search');
  els.crumbs.innerHTML = '<span class="crumb-link" data-action="home">Главная</span><span> / Результаты поиска</span>';
  els.crumbs.querySelector('[data-action="home"]').onclick = resetAll;
  clearChildren(els.searchResultsList);
  const q = query.trim().toLowerCase();
  const zoneVal = document.getElementById('zone-select').value;
  const matches = rawData.filter(i => {
    const textMatch = (i.s + ' ' + i.ss + ' ' + i.d + ' ' + i.sol).toLowerCase().includes(q);
    const zoneMatch = !zoneVal || (i.zone || '').split(',').map(z => z.trim()).includes(zoneVal);
    return textMatch && zoneMatch;
  });

  if (matches.length === 0) {
    const empty = document.createElement('div');
    empty.className = 'no-results';
    empty.textContent = 'Ничего не найдено по запросу «' + query + '»';
    els.searchResultsList.appendChild(empty);
    return;
  }

  matches.slice(0, 100).forEach(item => {
    const details = document.createElement('details');
    details.className = 'item';

    const summary = document.createElement('summary');
    // ① подсветка в заголовке + ③ зоны
    const titleRow2 = document.createElement('div');
    titleRow2.className = 'summary-title-row';
    titleRow2.innerHTML = highlight(item.s, q) + ' / ' + highlight(item.ss, q) + ' / ' + highlight(item.d, q);
    summary.appendChild(titleRow2);
    if (item.zone) {
      const zonesDiv = document.createElement('div');
      zonesDiv.className = 'zones';
      item.zone.split(',').map(z => z.trim()).filter(Boolean).forEach(z => {
        const tag = document.createElement('span');
        tag.className = 'zone-tag';
        tag.textContent = z;
        zonesDiv.appendChild(tag);
      });
      summary.appendChild(zonesDiv);
    }
    details.appendChild(summary);

    const body = document.createElement('div');
    body.className = 'body';
    body.appendChild(buildSolutionBlock(item, q));  // передаём query для подсветки
    details.appendChild(body);

    els.searchResultsList.appendChild(details);
  });
}

function setView(view) {
  els.hubView.hidden = view !== 'hub';
  els.navChoiceView.hidden = view !== 'navChoice';
  els.sectionsView.hidden = view !== 'sections';
  els.subsectionsView.hidden = view !== 'subsections';
  els.detailsView.hidden = view !== 'details';
  els.searchResultsView.hidden = view !== 'search';
  els.glossaryPageView.hidden = view !== 'glossaryPage';
  els.appsPageView.hidden = view !== 'appsPage';
  els.versionsPageView.hidden = view !== 'versionsPage';
  els.zonesView.hidden = view !== 'zones';
  els.zoneSubsectionsView.hidden = view !== 'zoneSubsections';
  els.zoneDetailsView.hidden = view !== 'zoneDetails';
  els.zoneSolutionsView.hidden = view !== 'zoneSolutions';
}

function updateCrumbs() {
  const parts = [];
  parts.push('<span class="crumb-link" data-action="home">Главная</span>');
  if (state.section) {
    parts.push('<span> / </span><span class="crumb-link" data-action="section">' + escapeHtml(state.section) + '</span>');
  }
  if (state.subsection) {
    parts.push('<span> / </span><span>' + escapeHtml(state.subsection) + '</span>');
  }
  els.crumbs.innerHTML = parts.join('');
  els.crumbs.querySelectorAll('[data-action]').forEach(el => {
    el.onclick = () => {
      if (el.dataset.action === 'home') resetAll();
      if (el.dataset.action === 'section') renderSubsections();
    };
  });
}

function escapeHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function selectSection(section) {
  state.section = section;
  state.subsection = null;
  renderSubsections();
}

function selectSubsection(subsection) {
  state.subsection = subsection;
  renderDetails();
}

function resetAll() {
  state.section = null;
  state.subsection = null;
  els.searchInput.value = '';
  renderHub();
}

document.getElementById('reset-btn').onclick = resetAll;
document.getElementById('back-to-sections').onclick = () => { state.section = null; renderSections(); };
document.getElementById('back-to-subsections').onclick = () => { state.subsection = null; renderSubsections(); };
document.getElementById('back-to-hub-from-sections').onclick = renderHub;
document.getElementById('back-to-hub-from-glossary').onclick = renderHub;
document.getElementById('back-to-hub-from-apps').onclick = renderHub;
document.getElementById('back-to-hub-from-versions').onclick = renderHub;
document.getElementById('back-to-hub-from-navchoice').onclick = renderHub;
document.getElementById('back-to-navchoice-from-zones').onclick = goToNavChoice;
document.getElementById('back-to-zones').onclick = renderZones;
document.getElementById('back-to-zone-subsections').onclick = function(){selectZone(state.zone);};
document.getElementById('back-to-zone-details').onclick = function(){selectZoneSS(state.zone_ss);};

let searchTimer = null;
els.searchInput.addEventListener('input', (e) => {
  clearTimeout(searchTimer);
  const value = e.target.value;
  searchTimer = setTimeout(() => {
    if (value.trim().length === 0) {
      resetAll();
    } else {
      renderSearchResults(value);
    }
  }, 200);
});

// ⑤ Заполнить выпадающий список зон
(function initZoneSelect() {
  const sel = document.getElementById('zone-select');
  const zones = [...new Set(
    rawData.flatMap(i => (i.zone || '').split(',').map(z => z.trim()).filter(Boolean))
  )].sort((a, b) => a.localeCompare(b, 'ru'));
  zones.forEach(z => {
    const opt = document.createElement('option');
    opt.value = z; opt.textContent = z;
    sel.appendChild(opt);
  });
  // при изменении зоны — повторить текущий поиск или сбросить
  sel.addEventListener('change', () => {
    const q = els.searchInput.value.trim();
    if (q.length > 0 || sel.value) {
      renderSearchResults(q || ' ');
    } else {
      renderSections();
    }
  });
})();


