<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Стандарт СМР ММ 3.1</title>
<style>
  /* ═══════════════════════════════════════════════════════
     ДИЗАЙН: тёмный фон, красный акцент
     Палитра: #000000 · #1b1b1b · #262626 · #c0200e · #e8e0da
  ═══════════════════════════════════════════════════════ */
  :root {
    --red:        #c0200e;
    --red-hover:  #a31a0b;
    --red-muted:  #2b0b06;
    --red-border: #6b1108;
    --bg:         #000000;
    --surface:    #1b1b1b;
    --surface-2:  #262626;
    --surface-3:  #303030;
    --text:       #e8e0da;
    --muted:      #8a7f7a;
    --border:     #2e2e2e;
    --border-2:   #3e3e3e;
	--blue:       #56a6ef;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.55;
  }

  /* ── Header ─────────────────────────────────────────── */
  header {
    background: var(--surface);
    border-bottom: 2px solid var(--red);
    padding: 0 20px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,.6);
  }
  .header-row {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 56px;
  }
  .header-brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .header-icon {
    width: 34px; height: 34px;
    background: var(--red);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .header-icon svg { width: 18px; height: 18px; stroke: #fff; fill: none; }
  header .title {
    font-size: 15px;
    font-weight: 700;
    margin: 0;
    letter-spacing: .01em;
    color: var(--text);
  }
  header .subtitle {
    font-size: 11px;
    color: var(--muted);
    margin: 0;
    letter-spacing: .04em;
    text-transform: uppercase;
  }
  header > .header-row > button,
  #reset-btn {
    background: none;
    border: 1px solid var(--border-2);
    color: var(--muted);
    font-size: 12px;
    font-family: inherit;
    cursor: pointer;
    padding: 5px 12px;
    border-radius: 5px;
    letter-spacing: .03em;
    transition: border-color .15s, color .15s;
  }
  #reset-btn:hover { border-color: var(--red); color: var(--red); }

  /* ── Breadcrumbs ─────────────────────────────────────── */
  nav.crumbs {
    max-width: 900px;
    margin: 0 auto;
    padding: 10px 20px 0;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: .02em;
  }
  nav.crumbs span.crumb-link { color: var(--red); cursor: pointer; }
  nav.crumbs span.crumb-link:hover { text-decoration: underline; }

  /* ── Main ────────────────────────────────────────────── */
  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 20px 80px;
  }

  /* ── Intro banner ────────────────────────────────────── */
  .intro {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--red);
    border-radius: 6px;
    padding: 14px 18px;
    margin-bottom: 16px;
  }
  .intro h2 {
    margin: 0 0 3px;
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }
  .intro p { margin: 0; color: var(--muted); font-size: 13px; }

  /* ── Grid ────────────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  @media (max-width: 600px) { .grid { grid-template-columns: 1fr; } }

  /* ── Section / subsection cards ─────────────────────── */
  .card-btn {
    display: block;
    width: 100%;
    text-align: left;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid transparent;
    border-radius: 6px;
    padding: 13px 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    font-family: inherit;
    transition: border-color .15s, background .15s;
    line-height: 1.4;
  }
  .card-btn:hover {
    border-color: var(--border-2);
    border-left-color: var(--red);
    background: var(--surface-2);
  }

  /* ── Back link ───────────────────────────────────────── */
  .back-link {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 13px;
    font-family: inherit;
    cursor: pointer;
    padding: 0;
    margin-bottom: 12px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color .15s;
  }
  .back-link:hover { color: var(--red); }

  /* ── Accordion ───────────────────────────────────────── */
  details.item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: 8px;
    overflow: hidden;
    transition: border-color .15s;
  }
  details.item:hover { border-color: var(--border-2); }
  details.item[open] { border-color: var(--red-border); }
  details.item[open] summary { border-bottom: 1px solid var(--border); }

  details.item summary {
    list-style: none;
    cursor: pointer;
    padding: 13px 16px;
    font-weight: 600;
    font-size: 14px;
    display: flex;
    flex-direction: column;
    gap: 0;
    color: var(--text);
    user-select: none;
    transition: background .12s;
  }
  details.item summary:hover { background: var(--surface-2); }
  details.item summary::-webkit-details-marker { display: none; }

  /* Chevron через псевдоэлемент на flex-row */
  details.item summary .summary-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }
  details.item summary .summary-title-row::after {
    content: "+";
    color: var(--red);
    font-size: 20px;
    font-weight: 300;
    line-height: 1;
    flex-shrink: 0;
  }
  details.item[open] summary .summary-title-row::after { content: "–"; }

  details.item .body {
    padding: 0 16px 16px;
  }

  /* ── Solution block ──────────────────────────────────── */
  .solution {
    padding-top: 14px;
    font-size: 13px;
    color: var(--text);
    line-height: 1.6;
  }
  .solution + .solution {
    border-top: 1px dashed var(--border-2);
    margin-top: 14px;
  }

  /* ── Tags ────────────────────────────────────────────── */
  .tags { margin-top: 10px; display: flex; flex-wrap: wrap; gap: 5px; }
  .tag {
    font-size: 11px;
    color: var(--muted);
    background: var(--surface-2);
    border: 1px solid var(--border-2);
    border-radius: 4px;
    padding: 3px 8px;
  }

  /* ── Зона в шапке карточки ───────────────────────────── */
  .zone-tag {
    display: inline-block;
    font-size: 11px; font-weight: 500;
    color: #e87070;
    background: var(--red-muted);
    border: 1px solid var(--red-border);
    border-radius: 10px;
    padding: 1px 7px;
    margin-left: 6px;
    vertical-align: middle; white-space: nowrap;
  }
  details.item summary .zones {
    display: flex; flex-wrap: wrap; gap: 4px;
    margin-top: 5px;
  }

  /* ── Empty / no-results ──────────────────────────────── */
  .empty { color: var(--muted); font-style: italic; padding: 14px 16px; font-size: 13px; }
  .no-results { text-align: center; color: var(--muted); padding: 40px 20px; font-size: 14px; }

  /* ── Search box ──────────────────────────────────────── */
  .search-box { margin-bottom: 14px; }
  .search-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .search-row input { flex: 1; min-width: 200px; }

  .search-box input {
    width: 100%;
    padding: 10px 14px;
    font-size: 14px;
    font-family: inherit;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    outline: none;
    transition: border-color .15s;
  }
  .search-box input::placeholder { color: var(--muted); }
  .search-box input:focus { border-color: var(--red); box-shadow: 0 0 0 2px var(--red-muted); }

  /* ── Zone select ─────────────────────────────────────── */
  .zone-select {
    padding: 9px 10px;
    font-size: 13px;
    font-family: inherit;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    min-width: 190px; max-width: 260px;
    cursor: pointer;
    outline: none;
    transition: border-color .15s;
  }
  .zone-select:focus { border-color: var(--red); }
  .zone-select option { background: var(--surface-2); }

  /* ── Toolbar ─────────────────────────────────────────── */
  .toolbar {
    display: none;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .toolbar.visible { display: flex; }
  .toolbar button {
    background: var(--surface-2);
    border: 1px solid var(--border-2);
    border-radius: 5px;
    padding: 6px 13px;
    font-size: 12px;
    font-family: inherit;
    cursor: pointer;
    color: var(--muted);
    letter-spacing: .02em;
    transition: border-color .15s, color .15s, background .15s;
  }
  .toolbar button:hover {
    background: var(--surface-3);
    border-color: var(--border-2);
    color: var(--text);
  }
  .btn-print {
    margin-left: auto;
    background: var(--red) !important;
    color: #fff !important;
    border-color: var(--red) !important;
    font-weight: 600;
  }
  .btn-print:hover { background: var(--red-hover) !important; }

  /* ── Highlight поиска ────────────────────────────────── */
  mark {
    background: #7a2a00;
    color: #ffb580;
    border-radius: 2px;
    padding: 0 2px;
    font-style: normal;
  }

  /* ── Scrollbar ───────────────────────────────────────── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--surface-3); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--red); }


  /* ── Плашки: Приложения, Понятия, Версификация ───── */
  .panel-block {
    margin-top: 10px;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--surface);
  }
  .panel-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 16px;
    background: none;
    border: none;
    color: var(--text);
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-align: left;
    transition: background .12s;
    gap: 8px;
  }
  .panel-trigger:hover { background: var(--surface-2); }
  .panel-trigger .panel-label {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .panel-trigger .panel-icon {
    width: 28px; height: 28px;
    background: var(--red-muted);
    border: 1px solid var(--red-border);
    border-radius: 5px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .panel-trigger .panel-icon svg {
    width: 14px; height: 14px;
    stroke: #e87070; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }
  .panel-chevron {
    color: var(--muted);
    font-size: 18px;
    font-weight: 300;
    transition: transform .2s;
    flex-shrink: 0;
  }
  .panel-block.open .panel-chevron { transform: rotate(45deg); }
  .panel-body {
    display: none;
    border-top: 1px solid var(--border);
    padding: 14px 16px;
  }
  .panel-block.open .panel-body { display: block; }

  /* ── Кнопки приложений ───────────────────────────────── */
  .apps-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .app-btn {
    background: var(--surface-2);
    border: 1px solid var(--border-2);
    border-radius: 5px;
    color: var(--text);
    font-family: inherit;
    font-size: 12px;
    padding: 6px 11px;
    cursor: pointer;
    text-align: left;
    line-height: 1.3;
    transition: border-color .15s, color .15s, background .15s;
  }
  .app-btn:hover {
    border-color: var(--red-border);
    color: #e87070;
    background: var(--red-muted);
  }
  .app-btn--nolink {
    opacity: .45;
    cursor: not-allowed;
  }
  .app-btn--nolink:hover {
    border-color: var(--border-2) !important;
    color: var(--muted) !important;
    background: var(--surface-2) !important;
  }

  /* ── Версионирование ─────────────────────────────────── */
  .version-form {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .version-form textarea {
    flex: 1;
    min-width: 200px;
    min-height: 70px;
    padding: 9px 12px;
    font-size: 13px;
    font-family: inherit;
    background: var(--surface-2);
    border: 1px solid var(--border-2);
    border-radius: 5px;
    color: var(--text);
    resize: vertical;
    outline: none;
    line-height: 1.5;
    transition: border-color .15s;
  }
  .version-form textarea::placeholder { color: var(--muted); }
  .version-form textarea:focus { border-color: var(--red); }
  .version-form .version-actions {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .btn-save-version {
    background: var(--red);
    color: #fff;
    border: none;
    border-radius: 5px;
    padding: 8px 16px;
    font-family: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background .15s;
  }
  .btn-save-version:hover { background: var(--red-hover); }
  .version-list { display: flex; flex-direction: column; gap: 8px; }
  .version-entry {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--red-border);
    border-radius: 5px;
    padding: 10px 12px;
    position: relative;
  }
  .version-meta {
    font-size: 11px;
    color: var(--muted);
    margin-bottom: 5px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .version-text {
    font-size: 13px;
    color: var(--text);
    line-height: 1.5;
    white-space: pre-wrap;
  }
  .btn-del-version {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 16px;
    cursor: pointer;
    padding: 0 2px;
    line-height: 1;
    flex-shrink: 0;
    transition: color .15s;
  }
  .btn-del-version:hover { color: var(--red); }
  .version-empty {
    font-size: 13px;
    color: var(--muted);
    font-style: italic;
    padding: 4px 0;
  }

  /* ── Print ───────────────────────────────────────────── */
  @media print {
    header, nav.crumbs, #search-view, .toolbar,
    .back-link, #reset-btn, #view-sections, #view-subsections,
    #view-search-results { display: none !important; }
    body { background: #fff !important; color: #111 !important; }
    details.item { break-inside: avoid; border: 1px solid #ccc !important; }
    details.item .body { display: block !important; }
  }

  .img-gallery { display:flex; flex-wrap:wrap; gap:6px; margin-top:10px; }
  .img-gallery-btn {
    display:inline-flex; align-items:center; gap:5px;
    background:var(--surface-2); border:1px solid var(--border-2);
    border-radius:5px; color:#e87070; font-size:12px; font-family:inherit;
    padding:5px 10px; text-decoration:none;
    transition:border-color .15s, background .15s; white-space:nowrap;
  }
  .img-gallery-btn:hover { border-color:var(--red-border); background:var(--red-muted); }
  .img-gallery-btn svg { width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0; }

  .img-gallery { display:flex; flex-wrap:wrap; gap:10px; margin-top:12px; }
  .img-thumb-wrap { flex:0 0 auto; }
  .img-thumb {
    display:block; max-width:220px; max-height:180px;
    width:auto; height:auto;
    border:1px solid var(--border-2); border-radius:6px;
    cursor:zoom-in; transition:border-color .15s, opacity .15s;
    background:var(--surface-2); object-fit:contain;
  }
  .img-thumb:hover { border-color:var(--red-border); opacity:.9; }
  .img-err {
    display:inline-flex; align-items:center; gap:5px;
    background:var(--surface-2); border:1px solid var(--border-2);
    border-radius:5px; color:var(--muted); font-size:12px;
    padding:5px 10px; text-decoration:none;
    transition:border-color .15s, color .15s, background .15s;
  }
  .img-err:hover { border-color:var(--red-border); color:#e87070; background:var(--red-muted); }
  #lightbox {
    display:none; position:fixed; inset:0;
    background:rgba(0,0,0,.88); z-index:9999;
    align-items:center; justify-content:center; cursor:zoom-out;
  }
  #lightbox.open { display:flex; }
  #lightbox img { max-width:92vw; max-height:92vh; border-radius:8px; object-fit:contain; box-shadow:0 8px 40px rgba(0,0,0,.7); }
  #lb-close { position:fixed; top:16px; right:20px; background:none; border:none; color:#fff; font-size:32px; cursor:pointer; opacity:.7; }
  #lb-close:hover { opacity:1; }
  #lb-counter { position:fixed; bottom:20px; left:50%; transform:translateX(-50%); color:rgba(255,255,255,.6); font-size:13px; }

  /* ── Титульный экран ─────────────────────────────── */
  #title-screen {
    position: fixed; inset: 0; z-index: 10000;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(180deg, rgba(14,14,14,.55), rgba(14,14,14,.92)),
                url('https://raw.githubusercontent.com/standart-SMR/smr_new/main/pic/title-bg.jpg')
                center/cover no-repeat, var(--bg);
    text-align: center;
    transition: opacity .35s ease, visibility .35s ease;
  }
  #title-screen.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
  #title-screen .ts-inner { max-width: 560px; padding: 0 24px; }
  #title-screen .ts-icon {
    width: 64px; height: 64px; margin: 0 auto 22px;
    background: var(--red); border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 30px rgba(192,32,14,.4);
  }
  #title-screen .ts-icon svg { width: 32px; height: 32px; stroke: #fff; fill: none; }
  #title-screen h1 {
    font-size: 26px; font-weight: 800; color: #fff; margin: 0 0 6px;
    letter-spacing: .01em; line-height: 1.25;
  }
  #title-screen p.ts-sub {
    color: rgba(255,255,255,.55); font-size: 14px; margin: 0 0 26px;
    letter-spacing: .03em; text-transform: uppercase;
  }
  #title-screen .ts-version {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.14);
    border-radius: 30px; padding: 7px 18px; margin-bottom: 30px;
    color: #fff; font-size: 13px;
  }
  #title-screen .ts-version b { color: #ff8a6a; font-weight: 700; }
  #title-screen .ts-enter {
    background: var(--red); color: #fff; border: none;
    border-radius: 8px; padding: 13px 36px; font-family: inherit;
    font-size: 15px; font-weight: 700; cursor: pointer;
    letter-spacing: .02em; transition: background .15s, transform .1s;
  }
  #title-screen .ts-enter:hover { background: var(--red-hover); }
  #title-screen .ts-enter:active { transform: scale(.97); }
  #title-screen .ts-footer {
    margin-top: 22px; font-size: 11px; color: rgba(255,255,255,.35);
    letter-spacing: .04em; text-transform: uppercase;
  }

  /* ── Полотно "Основные понятия" на главном экране ──── */
  .glossary-flow { font-size: 13px; line-height: 1.85; color: var(--text); }
  .glossary-flow b { color: #e87070; font-weight: 700; }

  /* ── Таблица версификации ────────────────────────── */
  .version-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  .version-table th {
    text-align: left; padding: 8px 10px; color: var(--muted);
    font-weight: 600; border-bottom: 1px solid var(--border-2);
    white-space: nowrap; position: sticky; top: 0; background: var(--surface);
  }
  .version-table td {
    padding: 9px 10px; border-bottom: 1px solid var(--border);
    vertical-align: top; color: var(--text);
  }
  .version-table tr:hover td { background: var(--surface-2); }
  .version-table .v-num { font-weight: 700; color: #e87070; white-space: nowrap; }
  .version-table .v-date { color: var(--muted); white-space: nowrap; }
  .version-table .v-changes {
    white-space: pre-line; max-width: 480px; font-size: 12px; line-height: 1.55;
  }
  .version-table-wrap { max-height: 460px; overflow-y: auto; border: 1px solid var(--border); border-radius: 6px; }
  .v-current-badge {
    display: inline-block; background: var(--red-muted); color: #e87070;
    border: 1px solid var(--red-border); border-radius: 4px;
    font-size: 10px; padding: 1px 6px; margin-left: 6px; font-weight: 600;
  }

  /* ── Хаб (4 кнопки на главной) ───────────────────── */
  .hub-card {
    display: flex !important;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 30px 16px !important;
    text-align: center !important;
    min-height: 140px;
  }
  .hub-card-icon {
