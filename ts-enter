function uniqueSorted(arr) {
  return [...new Set(arr)].sort((a, b) => a.localeCompare(b, 'ru'));
}

function getSections() {
  return uniqueSorted(rawData.map(i => i.s));
}
function getSubsections(section) {
  return uniqueSorted(rawData.filter(i => i.s === section).map(i => i.ss));
}
function getDetails(section, subsection) {
  return uniqueSorted(rawData.filter(i => i.s === section && i.ss === subsection).map(i => i.d));
}
function getSolutions(section, subsection, detail) {
  return rawData.filter(i => i.s === section && i.ss === subsection && i.d === detail);
}

function clearChildren(el) {
  while (el.firstChild) el.removeChild(el.firstChild);
}

function appendMultiline(container, text) {
  const lines = String(text || '').split('\n');
  lines.forEach((line, idx) => {
    container.appendChild(document.createTextNode(line));
    if (idx < lines.length - 1) container.appendChild(document.createElement('br'));
  });
}

function makeCardButton(label, onClick) {
  const btn = document.createElement('button');
  btn.className = 'card-btn';
  btn.textContent = label;
  btn.onclick = onClick;
  return btn;
}

function buildSolutionBlock(item, query) {
  const wrap = document.createElement('div');
  wrap.className = 'solution';

  const textEl = document.createElement('div');
  if (query) {
    // ① подсветка в тексте решения
    textEl.innerHTML = highlight(item.sol, query).replace(/\n/g, '<br>');
  } else {
    appendMultiline(textEl, item.sol);
  }
  wrap.appendChild(textEl);

  if (item.img && item.img.length) {
    const gallery = document.createElement('div');
    gallery.className = 'img-gallery';
    const previews = item.img.map(u => u + '/download');
    previews.forEach((src, n) => {
      const wr = document.createElement('div');
      wr.className = 'img-thumb-wrap';
      const img = document.createElement('img');
      img.src = src; img.loading = 'lazy'; img.className = 'img-thumb';
      img.title = 'Click to enlarge';
      img.onclick = () => lbOpen(previews, item.img, n);
      img.onerror = function() {
        const a = document.createElement('a');
        a.href = item.img[n]; a.target = '_blank'; a.rel = 'noopener';
        a.className = 'img-err'; a.textContent = 'Открыть изображение ' + (n+1);
        wr.replaceChild(a, this);
      };
      wr.appendChild(img); gallery.appendChild(wr);
    });
    wrap.appendChild(gallery);
  }

  const tags = document.createElement('div');
  tags.className = 'tags';

  if (item.app) {
    const t = document.createElement('span');
    t.className = 'tag';
    t.textContent = 'Приложение: ' + item.app.replace(/\n/g, ' ');
    tags.appendChild(t);
  }
  if (item.zone) {
    const t = document.createElement('span');
    t.className = 'tag';
    t.textContent = 'Зона: ' + item.zone;
    tags.appendChild(t);
  }
  if (tags.childNodes.length) wrap.appendChild(tags);

  return wrap;
}

function buildDetailItem(section, subsection, detail) {
  const solutions = getSolutions(section, subsection, detail);

  const details = document.createElement('details');
  details.className = 'item';

  const summary = document.createElement('summary');
  // ③ Зона применения в шапке карточки
  // title row (текст + chevron через CSS ::after)
  const titleRow = document.createElement('div');
  titleRow.className = 'summary-title-row';
  titleRow.appendChild(document.createTextNode(detail));
  summary.appendChild(titleRow);
  // зоны под заголовком
  const firstSol = solutions[0];
  if (firstSol && firstSol.zone) {
    const zonesDiv = document.createElement('div');
    zonesDiv.className = 'zones';
    firstSol.zone.split(',').map(z => z.trim()).filter(Boolean).forEach(z => {
      const tag = document.createElement('span');
      tag.className = 'zone-tag';
      tag.textContent = z;
      zonesDiv.appendChild(tag);
    });
    summary.appendChild(zonesDiv);
  }
  details.appendChild(summary);

  const body = document.createElement('div');
  body.className = 'body';

  if (solutions.length === 0) {
    const empty = document.createElement('p');
    empty.className = 'empty';
    empty.textContent = 'Техническое решение отсутствует или не описано.';
    body.appendChild(empty);
  } else {
    solutions.forEach(sol => body.appendChild(buildSolutionBlock(sol)));
  }

  details.appendChild(body);
  return details;
}


/* ── Подсветка ────────────────────────────────────────────── */
function escapeRe(str) {
  return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}
function highlight(rawText, query) {
  const safe = escapeHtml(String(rawText || ''));
  if (!query) return safe;
  return safe.replace(new RegExp('(' + escapeRe(escapeHtml(query)) + ')', 'gi'), '<mark>$1</mark>');
}

/* ── Раскрыть / Свернуть все ───────────────────────────────── */
function expandAll()  { document.querySelectorAll('details.item').forEach(d => d.open = true);  }
function collapseAll(){ document.querySelectorAll('details.item').forEach(d => d.open = false); }

/* ── Печать ─────────────────────────────────────────────────── */
